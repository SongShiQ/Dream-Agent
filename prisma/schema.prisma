// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// 学员档案
model Student {
  id            String   @id @default(cuid())
  name          String
  email         String?  @unique
  currentStage  String   @default("pre_study_theory")
  weakPoints    String   @default("[]") // JSON array as string
  feedbackMode  String   @default("hybrid") // guided | direct | hybrid
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // 关联
  assessments   Assessment[]
  answerRecords AnswerRecord[]
  learningPlan  LearningPlan?
  codeSubmissions CodeSubmission[]
  chatSessions  ChatSession[]

  @@index([currentStage])
}

// 水平评估
model Assessment {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  theory      Int      @default(0) // 0-100
  coding      Int      @default(0) // 0-100
  rust        Int      @default(0) // 0-100
  weakPoints  String   @default("[]") // JSON array as string
  assessedAt  DateTime @default(now())

  @@index([studentId])
}

// 题目
model Question {
  id              String   @id @default(cuid())
  type            String   // choice | fill | code | design
  difficulty      Int      @default(50) // 0-100
  knowledgePoints String   @default("[]") // JSON array as string
  content         String
  options         String   @default("[]") // JSON array as string
  answer          String
  explanation     String
  stage           String   @default("basic") // 导学|基础|专业|项目
  createdAt       DateTime @default(now())

  // 关联
  answerRecords AnswerRecord[]

  @@index([type])
  @@index([difficulty])
  @@index([stage])
}

// 答题记录
model AnswerRecord {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer      String
  isCorrect   Boolean
  timeSpent   Int      @default(0) // 秒
  feedbackMode String  @default("hybrid") // guided | direct | hybrid
  answeredAt  DateTime @default(now())

  @@index([studentId])
  @@index([questionId])
  @@index([answeredAt])
}

// 学习计划
model LearningPlan {
  id                  String    @id @default(cuid())
  studentId           String    @unique
  student             Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  currentStage        String
  dailyTasks          String    @default("[]") // JSON as string
  weeklyGoals         String    @default("[]") // JSON array as string
  estimatedCompletion DateTime?
  lastAdjustedAt      DateTime  @default(now())

  @@index([currentStage])
}

// 代码提交记录
model CodeSubmission {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  labName     String   // lab1-batch, lab2-address, etc.
  code        String   // 提交的代码
  language    String   @default("rust") // rust | c | asm
  testResult  String   // 测试结果
  isPassed    Boolean  @default(false)
  feedback    String   // AI 反馈
  createdAt   DateTime @default(now())

  @@index([studentId])
  @@index([labName])
  @@index([createdAt])
}

// 聊天会话（按学员 + 模式）
model ChatSession {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  mode      String   @default("chat") // chat | practice | assess | plan
  title     String   @default("新会话")
  summary   String   @default("") // L2 轻量摘要
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  ChatMessage[]

  @@index([studentId, mode])
  @@index([updatedAt])
}

// 聊天消息
model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String   // user | assistant | system
  content   String
  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
}
