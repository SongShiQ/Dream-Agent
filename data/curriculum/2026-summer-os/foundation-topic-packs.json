          "remediationCardIds": ["os-theory-02-process-thread"]
        },
        {
          "id": "pcb-stores-source-code",
          "label": "PCB 主要保存用户程序源码，切换进程不需要保存 CPU 执行现场。",
          "questionTags": ["pcb"],
          "remediationCardIds": ["os-theory-02-process-thread"]
        },
        {
          "id": "smaller-timeslice-always-better",
          "label": "时间片越小响应一定越好，而且不会增加上下文切换开销。",
