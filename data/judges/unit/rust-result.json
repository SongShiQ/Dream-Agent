{
  "gateId": "rust-result",
  "title": "Rust · Result 与错误处理",
  "publicDescription": "提交一个使用 Result<T, E>、? 或 match 处理可恢复错误的最小 Rust 片段。",
  "rules": [
    {
      "id": "result-type",
      "description": "使用 Result<T, E> 或 Result<...>",
      "requiredIncludes": ["Result"]
    },
    {
      "id": "error-flow",
      "description": "使用 ? 或 match 处理错误分支",
      "requiredAnyIncludes": ["?", "match"]
    },
    {
      "id": "ok-err",
      "description": "体现 Ok/Err 结果",
      "requiredAnyIncludes": ["Ok(", "Err("]
    }
  ],
  "forbiddenIncludes": ["unwrap()", "expect(", "todo!()", "unimplemented!()"],
  "harness": {
    "mode": "rust_single_file",
    "template": "{{submission}}\n\n#[cfg(test)]\nmod opencamp_hidden_tests {\n    use super::*;\n{{tests}}\n}\n",
    "tests": "    #[test]\n    fn result_gate_compiles() {\n        main();\n    }\n"
  }
}
