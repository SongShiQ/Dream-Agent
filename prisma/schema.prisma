// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// 学员档案
model Student {
  id            String   @id @default(cuid())
  name          String
  email         String?  @unique
  currentStage  String   @default("pre_study_theory")
  cohortId      String   @default("2026-summer-os-main")
  learningStatus String @default("active") // active | paused | project_candidate | project_confirmed | archived
  curriculumVersion String @default("2026-summer-os")
  weakPoints    String   @default("[]") // JSON array as string
  feedbackMode  String   @default("hybrid") // guided | direct | hybrid
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // 关联
  assessments   Assessment[]
  answerRecords AnswerRecord[]
  learningPlan  LearningPlan?
  codeSubmissions CodeSubmission[]
  chatSessions  ChatSession[]
  labGateProgress LabGateProgress[]
  dailyTaskProgress DailyTaskProgress[]
  foundationQuizAttempts FoundationQuizAttempt[]
  reviewSchedules ReviewSchedule[]
  experimentAttempts ExperimentAttempt[]

  // 助教主路径完成（全部 unit/integration 关 AC 后）
  assistantPathCompletedAt DateTime?

  @@index([currentStage])
  @@index([cohortId])
  @@index([learningStatus])
}

// 水平评估
model Assessment {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  theory      Int      @default(0) // 0-100
  coding      Int      @default(0) // 0-100
  rust        Int      @default(0) // 0-100
  weakPoints  String   @default("[]") // JSON array as string
  assessedAt  DateTime @default(now())

  @@index([studentId])
}

// 题目
model Question {
  id              String   @id @default(cuid())
  type            String   // choice | fill | code | design
  difficulty      Int      @default(50) // 0-100
  knowledgePoints String   @default("[]") // JSON array as string
  content         String
  options         String   @default("[]") // JSON array as string
  answer          String
  explanation     String
  stage           String   @default("basic") // 导学|基础|专业|项目
  createdAt       DateTime @default(now())

  // 关联
  answerRecords AnswerRecord[]

  @@index([type])
  @@index([difficulty])
  @@index([stage])
}

// 答题记录
model AnswerRecord {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer      String
  isCorrect   Boolean
  timeSpent   Int      @default(0) // 秒
  feedbackMode String  @default("hybrid") // guided | direct | hybrid
  answeredAt  DateTime @default(now())
  foundationAttemptId String?
  foundationAttempt   FoundationQuizAttempt? @relation(fields: [foundationAttemptId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([questionId])
  @@index([answeredAt])
  @@index([foundationAttemptId])
}

// 导学微单元小测：晋级/达标只能看 attempt 结果，不直接从普通练习题推断
model FoundationQuizAttempt {
  id                String   @id @default(cuid())
  studentId         String
  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  curriculumVersion String   @default("2026-summer-os")
  unitId            String
  mode              String   @default("practice") // practice | high_stakes
  status            String   @default("in_progress") // in_progress | passed | failed
  questionIds       String   @default("[]") // JSON array
  correct           Int      @default(0)
  total             Int      @default(0)
  correctRate       Int      @default(0)
  requiredCorrectRate Int    @default(80)
  attemptDate       String   // YYYY-MM-DD
  startedAt         DateTime @default(now())
  submittedAt       DateTime?
  answerRecords     AnswerRecord[]

  @@index([studentId, unitId])
  @@index([studentId, attemptDate])
  @@index([unitId, status])
}

// 确定性复习调度：只由小测/Judge 等证据更新，不由 LLM 自报掌握度写入
model ReviewSchedule {
  id                   String   @id @default(cuid())
  studentId            String
  student              Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  curriculumVersion    String   @default("2026-summer-os")
  targetType           String   // foundation_unit | gate
  targetId             String
  state                String   @default("scheduled") // due | scheduled | completed | snoozed
  repetition           Int      @default(0)
  intervalDays         Int      @default(0)
  dueDate              String   // YYYY-MM-DD（学员本地日历）
  lastEvidenceType     String   @default("")
  lastEvidenceId       String   @default("")
  lastEvidencePassed   Boolean  @default(false)
  lastEvidenceAt       DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([studentId, curriculumVersion, targetType, targetId])
  @@index([studentId, dueDate, state])
  @@index([targetType, targetId])
}

// 参数化预实验：仅形成性练习，不写入 mastery、LabGateProgress 或 CodeSubmission
model ExperimentAttempt {
  id              String   @id @default(cuid())
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseVersion   String
  templateId      String
  templateVersion Int
  instanceId      String
  variantIndex    Int
  status          String   @default("in_progress") // in_progress | submitted
  promptSnapshot  String
  inputSnapshot   String   // JSON；不包含 expected / hidden cases
  answer           String   @default("")
  isCorrect        Boolean?
  feedback         String   @default("")
  activeKey        String?  @unique // 仅进行中 attempt 持有，提交后清空
  startedAt        DateTime @default(now())
  submittedAt      DateTime?

  @@index([studentId, courseVersion, templateId, startedAt])
  @@index([studentId, status, startedAt])
  @@index([templateId, status])
}

// 学习计划
model LearningPlan {
  id                  String    @id @default(cuid())
  studentId           String    @unique
  student             Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  currentStage        String
  dailyTasks          String    @default("[]") // JSON as string
  weeklyGoals         String    @default("[]") // JSON array as string
  estimatedCompletion DateTime?
  lastAdjustedAt      DateTime  @default(now())

  @@index([currentStage])
}

// 个人待办完成态：只表示 personal_done，不参与课程达标或晋级
model DailyTaskProgress {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date        String   // YYYY-MM-DD，按学员本地日历
  taskId      String
  fingerprint String   @default("")
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([studentId, date, taskId])
  @@index([studentId, date])
  @@index([taskId])
}

// 代码提交记录（OJ 纪律：isPassed 仅当 verdict=AC）
model CodeSubmission {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  labName     String   // 兼容旧字段；同 gateId
  gateId      String   @default("") // env-setup | rustlings-xx | lab2-address ...
  code        String   // 提交的代码 / 补丁说明
  language    String   @default("rust") // rust | c | asm
  testResult  String   @default("") // 测试输出摘要
  /// AC | WA | CE | RE | TLE | SE | PENDING | STATIC
  /// STATIC = 仅静态分析，绝不能当作过关
  verdict     String   @default("PENDING")
  judgeKind   String   @default("none") // none | unit_oj | integration_oj | manual_teacher
  judgeLog    String   @default("") // 截断日志
  /// 仅 verdict==AC 时为 true；禁止客户端自报写 true
  isPassed    Boolean  @default(false)
  feedback    String   @default("") // 静态分析或评测说明
  createdAt   DateTime @default(now())
  judgeJobs   JudgeJob[]
  judgeRuns   JudgeRun[]

  @@index([studentId])
  @@index([labName])
  @@index([gateId])
  @@index([verdict])
  @@index([createdAt])
}

// 判题队列：Web 只入队，worker 独立消费；只有评测结果 AC 才能推进关卡
model JudgeJob {
  id          String   @id @default(cuid())
  submissionId String @unique
  submission CodeSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  studentId   String
  gateId      String
  judgeKind   String   @default("unit_oj") // unit_oj | integration_oj
  status      String   @default("queued") // queued | running | completed | failed | cancelled
  priority    Int      @default(0)
  attempts    Int      @default(0)
  maxAttempts Int      @default(2)
  leaseOwner  String?
  leaseUntil  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  runs        JudgeRun[]

  @@index([status, priority, createdAt])
  @@index([studentId, gateId])
  @@index([submissionId])
}

// 单次判题运行记录：保留 verdict 与公共日志，便于审计与重建进度
model JudgeRun {
  id          String   @id @default(cuid())
  jobId       String
  job         JudgeJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  submissionId String
  submission CodeSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  verdict     String   @default("PENDING")
  status      String   @default("completed") // completed | system_error
  publicLog   String   @default("")
  rawLog      String   @default("")
  exitCode    Int?
  timeMs      Int?
  memoryKb    Int?
  startedAt   DateTime @default(now())
  finishedAt  DateTime @default(now())

  @@index([jobId])
  @@index([submissionId])
  @@index([verdict])
}

// 运营风险处理状态：风险项仍动态计算，这里记录处理闭环
model RiskResolution {
  id          String   @id @default(cuid())
  riskId      String   @unique
  status      String   @default("open") // open | acknowledged | resolved | ignored
  note        String   @default("")
  handledBy   String   @default("")
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([status])
  @@index([updatedAt])
}

// 教师内容审核决策：网页记录决策，CLI/CI 校验哈希后再写入 Git 内容文件
model ContentReviewDecision {
  id             String   @id @default(cuid())
  targetKind     String   // knowledge_card | experiment_template
  targetId       String
  sourcePath     String
  courseVersion  String
  action         String   // approve_review | request_changes | publish | deprecate
  status         String   @default("pending") // pending | applied | stale | cancelled
  activeKey      String?  @unique
  actor          String
  note           String   @default("")
  expectedHash   String
  proposedHash   String
  beforeState    String
  afterState     String
  failureReason  String   @default("")
  createdAt      DateTime @default(now())
  appliedAt      DateTime?

  @@index([targetKind, targetId, createdAt])
  @@index([status, createdAt])
  @@index([actor, createdAt])
}

// 实验关卡进度（OJ：passed 仅由 AC 提交写入）
model LabGateProgress {
  id           String    @id @default(cuid())
  studentId    String
  student      Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  gateId       String
  /// locked | unlocked | passed
  status       String    @default("locked")
  passedAt     DateTime?
  bestVerdict  String?
  passSubmitId String?
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())

  @@unique([studentId, gateId])
  @@index([studentId, status])
  @@index([gateId])
}

// 聊天会话（按学员 + 模式）
model ChatSession {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  mode      String   @default("chat") // chat | practice | assess | plan
  title     String   @default("新会话")
  summary   String   @default("") // L2 轻量摘要
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  ChatMessage[]

  @@index([studentId, mode])
  @@index([updatedAt])
}

// 聊天消息
model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String   // user | assistant | system
  content   String
  knowledgeRefs String  @default("[]") // JSON: 检索依据摘要，不复制知识正文
  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
}
